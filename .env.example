# Example environment configuration for Cockpit when Nacos is the source of truth.
# Copy this file to `.env` before starting the container.
# Cockpit loads and publishes config through Nacos.

# ------------------------------------------------------------------------------
# Management API authentication
# ------------------------------------------------------------------------------
# /api/* requests must send Authorization: Bearer <MANAGEMENT_PASSWORD>
MANAGEMENT_PASSWORD=change-me

# ------------------------------------------------------------------------------
# Nacos bootstrap
# ------------------------------------------------------------------------------
NACOS_ADDR=nacos:8848
# NACOS_NAMESPACE=public
# NACOS_GROUP=DEFAULT_GROUP
# NACOS_USERNAME=nacos
# NACOS_PASSWORD=nacos
# NACOS_CACHE_DIR=/tmp/nacos/cache
